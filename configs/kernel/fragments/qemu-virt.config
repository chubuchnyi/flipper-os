# Kernel config fragment for QEMU aarch64 virt machine support
# Apply via: scripts/kconfig/merge_config.sh .config fragments/qemu-virt.config

# PL011 UART (QEMU virt serial console — ttyAMA0)
CONFIG_SERIAL_AMBA_PL011=y

# Allow virtio-mmio devices via kernel command line
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
