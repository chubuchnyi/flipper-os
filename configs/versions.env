# Flipper OS — Pinned upstream component versions
# Update these when rebasing on newer upstream

# Flipper build scripts (our fork)
BUILD_SCRIPTS_REPO=git@github.com:YOUR_GH/flipperone-linux-build-scripts.git
BUILD_SCRIPTS_BRANCH=flipper-os/base

# Kernel — use Flipper fork as-is
KERNEL_REPO=https://github.com/flipperdevices/flipper-linux-kernel.git
KERNEL_REF=main
# The SHA at the moment of pinning (update when upgrading):
KERNEL_SHA=aebf809aae545dd5653716c2f24112e2114d9552

# U-Boot — Flipper fork
UBOOT_REPO=https://github.com/flipperdevices/u-boot.git
UBOOT_REF=master
UBOOT_SHA=0ab6276cc7383069ed5a609dc9147e7c03cea67d

# Collabora kernel (reference, for comparison)
COLLABORA_REPO=https://gitlab.collabora.com/hardware-enablement/rockchip-3588/linux.git
COLLABORA_BRANCH=rockchip-devel

# kwiboo U-Boot (extended RK3576 board support)
KWIBOO_REPO=https://source.denx.de/u-boot/contributors/kwiboo/u-boot.git
KWIBOO_BRANCH=rk3576
