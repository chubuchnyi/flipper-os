[Unit]
Description=Flipper OS Profile Daemon
Documentation=https://github.com/nickolay-github/flipper-os
After=local-fs.target
ConditionPathExists=/data/.last-profile

[Service]
Type=simple
ExecStart=/usr/lib/flipper-os/flipper-profiled
Restart=on-failure
RestartSec=10

# Hardening
ProtectSystem=strict
ReadWritePaths=/data /run
NoNewPrivileges=yes
ProtectHome=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictRealtime=yes
MemoryDenyWriteExecute=yes
LockPersonality=yes

[Install]
WantedBy=multi-user.target
